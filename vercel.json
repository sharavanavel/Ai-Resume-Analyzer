{
    "version": 2,
    "buildCommand": "cd client && npm install && npm run build",
    "outputDirectory": "client/dist",
    "installCommand": "cd server && npm install && cd ../client && npm install",
    "framework": null,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/health",
            "destination": "/api"
        },
        {
            "source": "/(.*)",
            "destination": "/$1"
        }
    ]
}